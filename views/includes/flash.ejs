<%
    let flashSuccess = [];
    let flashError = [];
    if (typeof success !== 'undefined') {
        flashSuccess = Array.isArray(success) ? success : [success];
    } else if (typeof locals !== 'undefined' && typeof locals.success !== 'undefined') {
        flashSuccess = Array.isArray(locals.success) ? locals.success : [locals.success];
    }
    if (typeof error !== 'undefined') {
        flashError = Array.isArray(error) ? error : [error];
    } else if (typeof locals !== 'undefined' && typeof locals.error !== 'undefined') {
        flashError = Array.isArray(locals.error) ? locals.error : [locals.error];
    }
%>
<% if (flashSuccess.length) { %>
    <% flashSuccess.forEach(msg => { %>
        <div class="alert alert-success alert-dismissible fade show col-6 offset-3" role="alert">
            <%= msg %>
            <button 
                type="button" 
                class="btn-close" 
                data-bs-dismiss="alert" 
                aria-label="Close">
            </button>
        </div>
    <% }) %>
<% } %>

<% if (flashError.length) { %>
    <% flashError.forEach(msg => { %>
        <div class="alert alert-danger alert-dismissible fade show col-6 offset-3" role="alert">
            <%= msg %>
            <button 
                type="button" 
                class="btn-close" 
                data-bs-dismiss="alert" 
                aria-label="Close">
            </button>
        </div>
    <% }) %>
<% } %>
