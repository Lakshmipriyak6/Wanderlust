<% layout("layouts/boilerplate") %>

<body>
  <div class="listings-header">
    <h3>All Listings</h3>

    <div class="tax-toggle" aria-label="Display total after taxes">
      <span>Display total after taxes</span>
      <label class="switch">
        <input type="checkbox" id="taxSwitch">
        <span class="slider"></span>
      </label>
    </div>
  </div>

  <div class="listing-toolbar" aria-label="Listing filters">
    <button type="button" class="filter-chip active" data-filter="all">
      <i class="fa-solid fa-fire"></i>
      <span>All</span>
    </button>
    <button type="button" class="filter-chip" data-filter="mountain">
      <i class="fa-solid fa-mountain-sun"></i>
      <span>Mountains</span>
    </button>
    <button type="button" class="filter-chip" data-filter="beach">
      <i class="fa-solid fa-umbrella-beach"></i>
      <span>Beach</span>
    </button>
    <button type="button" class="filter-chip" data-filter="city">
      <i class="fa-solid fa-city"></i>
      <span>City</span>
    </button>
    <button type="button" class="filter-chip" data-filter="lake">
      <i class="fa-solid fa-water"></i>
      <span>Lakefront</span>
    </button>
  </div>

  <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1 g-4">
    <% for (let listing of allListings) { %>
      <a
        href="/listings/<%= listing._id %>"
        class="listing-link"
        data-search="<%= `${listing.title} ${listing.location} ${listing.country} ${listing.description}`.toLowerCase() %>"
      >
        <div class="card col listing-card">
          <img
            src="<%= listing.image?.url || 'https://via.placeholder.com/400x250?text=No+Image' %>"
            class="card-img-top"
            alt="listing_image"
            style="height: 20rem"
          />
          <% if (listing.isGhost) { %>
            <div class="ghost-pill">GHOST</div>
          <% } %>
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br />
              <span class="listing-price" data-price="<%= listing.price %>">
                &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
              </span>
            </p>
          </div>
        </div>
      </a>
    <% } %>
  </div>
</body>
