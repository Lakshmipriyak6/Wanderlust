<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <!-- <br><br> -->
<h3>Create a New Listing</h3>
<form method="POST" action="/listings" 
novalidate 
class="needs-validation" 
enctype="multipart/form-data"
>

  <div class="mb-3">
    <label for="title" class="form-label">Title</label>
    <input
      name="listing[title]"
      placeholder="Add a catchy title"
      type="text"
      class="form-control"
      required
    />
  <div class="valid-feedback">Title looks good!</div>
  </div>

  <div class="mb-3">
    <label for="description" class="form-label">Description</label>
    <textarea
      name="listing[description]"
      class="form-control" required
    ></textarea>
     <div class="invalid-feedback">Please enter a short description.</div>
  </div>
  
   <div class="mb-3">
    <label for="image" class="form-label">Upload Listing Image</label>
    <input
      name="listing[image]"
      type="file"
      class="form-control"
      required
    />
  </div>
<div class="row">
  <div class="mb-3 col-md-4">
    <label for="price" class="form-label">Price</label>
    <input
      name="listing[price]"
      placeholder="1200"
      type="text"
      class="form-control"  required
    />
    <div class="invalid-feedback">Price name should be valid.</div>
  </div>

  <div class="mb-3 col-md-8">
    <label for="country" class="form-label">Country</label>
    <input
      name="listing[country]"
      placeholder="India"
      class="form-control"  required
    />
    <div class="invalid-feedback">Country name should be valid.</div>
  </div>
</div>

  <div class="mb-3">
    <label for="location" class="form-label">Location</label>
    <input
      name="listing[location]"
      placeholder="Hyderabad, Telangana"
      type="text"
      class="form-control"
       required
    /> 
     <div class="invalid-feedback">Country name should be valid.</div>
  </div>

  <div class="row">
    <div class="mb-3 col-md-4 form-check">
      <input class="form-check-input" type="checkbox" value="true" id="isGhost" name="listing[isGhost]">
      <label class="form-check-label" for="isGhost">Ghost Listing (24hr flash)</label>
    </div>
    <div class="mb-3 col-md-4">
      <label class="form-label">Ghost Price</label>
      <input class="form-control" name="listing[ghostPrice]" placeholder="Discounted price" />
    </div>
    <div class="mb-3 col-md-4">
      <label class="form-label">Ghost Expires (ISO datetime)</label>
      <input class="form-control" name="listing[ghostExpires]" type="datetime-local" />
    </div>
  </div>

  <div class="mb-3 form-check">
    <input class="form-check-input" type="checkbox" id="ecoCertified" name="listing[ecoCertified]" value="true">
    <label class="form-check-label" for="ecoCertified">Eco Certified</label>
  </div>
  <br><br>
  <button class="btn btn-dark add-btn mt-3">Add</button>
  <br><br>
</form>
  </div>
 </div> 
