<% layout("layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-8 offset-2">

    <h3>Edit your Listing</h3>

    <form method="POST"
          action="/listings/<%= listing._id %>?_method=PUT"
          novalidate
          class="needs-validation">

      <!-- Title -->
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input
          class="form-control"
          name="listing[title]"
          value="<%= listing.title %>"
          required
        >
        <div class="valid-feedback">Title looks good!</div>
        <div class="invalid-feedback">Please enter a valid title.</div>
      </div>

      <!-- Description -->
      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea
          class="form-control"
          name="listing[description]"
          required
        ><%= listing.description %></textarea>
        <div class="invalid-feedback">Please enter a short description.</div>
      </div>

      <!-- Image -->
      <div class="mb-3">
        <label class="form-label">Image Link</label>
        <input
          class="form-control"
          name="listing[image][url]"
          value="<%= listing.image.url %>"
          type="text"
        >
        <div class="invalid-feedback">Please provide a valid image URL.</div>
      </div>

      <div class="row">
        <!-- Price -->
        <div class="mb-3 col-md-4">
          <label class="form-label">Price</label>
          <input
            class="form-control"
            name="listing[price]"
            value="<%= listing.price %>"
            required
          >
          <div class="invalid-feedback">Price name should be valid.</div>
        </div>

        <!-- Country -->
        <div class="mb-3 col-md-8">
          <label class="form-label">Country</label>
          <input
            class="form-control"
            name="listing[country]"
            value="<%= listing.country %>"
            required
          >
          <div class="invalid-feedback">Country name should be valid.</div>
        </div>
      </div>

      <!-- Location -->
      <div class="mb-3">
        <label class="form-label">Location</label>
        <input
          class="form-control"
          name="listing[location]"
          value="<%= listing.location %>"
          required
        >
        <div class="invalid-feedback">Location name should be valid.</div>
      </div>

      <button class="btn btn-dark edit-btn mt-3">Edit</button>
    </form>
  </div>
</div>

<script src="/js/script.js"></script>
